{
  "name": "openclaw-memory",
  "version": "2.3.0",
  "description": "Long-term memory with semantic search (SurrealDB backend, Cloud-only LLM)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "mammoth": "^1.7.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.11"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
