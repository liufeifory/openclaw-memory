{
  "name": "openclaw-memory",
  "version": "2.2.0",
  "description": "Long-term memory with semantic search (SurrealDB backend)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node dist/test-full.js",
    "test:surreal": "node dist/test-surreal.js",
    "test:recall": "node dist/test-recall.js",
    "test:conflict": "node dist/test-conflict.js",
    "test:features": "node dist/test-features.js",
    "test:graph": "node dist/test-graph-operations.js",
    "profile": "node dist/profile.js",
    "test:v27": "node dist/test-v27.js",
    "test:entity-extractor": "node dist/test-entity-extractor.js",
    "test:entity-indexer": "node dist/test-entity-indexer.js",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "surrealdb": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.11"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
