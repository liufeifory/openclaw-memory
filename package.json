{
  "name": "openclaw-memory",
  "version": "2.1.0",
  "description": "Qdrant-based long-term memory with semantic search",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node dist/test-full.js",
    "test:quick": "node dist/test.js",
    "migrate": "node dist/migrate.js"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.7.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.11"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
